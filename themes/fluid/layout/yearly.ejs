<%
page.layout = "yearly"
page.title = "年度总结"
page.subtitle = "每年的个人总结与回顾"
page.banner_img = theme.archive.banner_img
page.banner_img_height = theme.archive.banner_img_height
page.banner_mask_alpha = theme.archive.banner_mask_alpha
%>

<%
// 获取 yearly 分类的文章
var yearlyPosts = [];
if (site.categories && site.categories.length) {
  site.categories.forEach(function(cat) {
    if (cat.name === 'yearly') {
      cat.posts.forEach(function(post) {
        yearlyPosts.push(post);
      });
    }
  });
}
// 按日期倒序排序
yearlyPosts.sort(function(a, b) {
  return b.date - a.date;
});
%>

<div class="list-group">
  <p class="h4">年度总结</p>
  <hr>
  <% var dateCursor %>
  <% yearlyPosts.forEach(function (post) { %>
    <% if(date(post.date, "YYYY") !== dateCursor) { %>
      <% dateCursor = date(post.date, "YYYY") %>
      <p class="h5"><%= dateCursor %></p>
    <% } %>
    <a href="<%= url_for(post.path) %>" class="list-group-item list-group-item-action">
      <time><%= date(post.date, "MM-DD") %></time>
      <div class="list-group-item-title"><%= post.title %></div>
    </a>
  <% }) %>
</div>

<% if (yearlyPosts.length === 0) { %>
  <p style="text-align:center; color:#999; margin-top:2rem;">暂无年度总结，敬请期待。</p>
<% } %>
